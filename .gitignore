**/.openclaude/settings.local.json

# Local and remote experiment artifacts
.venv/
.paper-venv/
__pycache__/
*.py[cod]
.cache/
data/raw/
data/processed/images/
data/processed/checkpoints/
data/processed*/images/
data/processed*/checkpoints/
data/heldout-raw-cache/
data/external-heldout-v1/images/
models/
results/raw/
results/**/*.jsonl
results/**/*.parquet
results/**/route.json

# Credentials and local configuration
.env
*.pem
*.key

# LaTeX build intermediates
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out

# Reproducible paper delivery artifacts and duplicate figure formats
paper/overleaf-package.zip
paper/arxiv-source.zip
paper/figures/generated-*.png
paper/figures/generated-*.svg
